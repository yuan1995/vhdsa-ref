
#ifdef HAVE_CONFIG_H
#include <config.h>
#endif

#include "vhdsa_@PARAM_L@.h"
#include "aes.h"
#include "compat.h"
#include "vhdsa_impl.h"
#include "instances.h"
#include "owf.h"
#include "parameters.h"
#include "randomness.h"
#include "utils.h"

#include <stdlib.h>
#include <string.h>

// memory layout of the public key: OWF input || OWF output
#define PK_INPUT(pk) (pk)
#define PK_OUTPUT(pk) (&pk[@OWF_INPUT_SIZE@])

// memory layout of the secret key: OWF input || OWF key
#define SK_INPUT(sk) (sk)
#define SK_KEY(sk) (&sk[@OWF_INPUT_SIZE@])

static_assert(@PK_SIZE@ == @OWF_INPUT_SIZE@ + @OWF_OUTPUT_SIZE@, "invalid public key size");
static_assert(@SK_SIZE@ == @OWF_INPUT_SIZE@ + @LAMBDA@ / 8, "invalid secret key size");

int VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_keygen(uint8_t* pk, uint8_t* sk) {
  if (!pk || !sk) {
    return -1;
  }

  bool done = false;
  while (!done) {
    rand_bytes(SK_KEY(sk), @LAMBDA@  / 8);
    done = (ptr_get_bit(SK_KEY(sk), 0) & ptr_get_bit(SK_KEY(sk), 1)) == 0;
    vhdsa_declassify(&done, sizeof(done));
  }
  rand_bytes(SK_INPUT(sk), @OWF_INPUT_SIZE@);
  // declassify OWF input
  vhdsa_declassify(SK_INPUT(sk), @OWF_INPUT_SIZE@);
  vhdsa_@PARAM_L@_owf(SK_KEY(sk), SK_INPUT(sk), PK_OUTPUT(pk));
  memcpy(PK_INPUT(pk), SK_INPUT(sk), @OWF_INPUT_SIZE@);

  // declassify public key
  vhdsa_declassify(pk, @PK_SIZE@);
  return 0;
}

int VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_unpack_private_key(vhdsa_@PARAM_L@_unpacked_private_key_t* unpacked_sk, const uint8_t* sk) {
  if (!unpacked_sk || !sk) {
    return -1;
  }

  memcpy(unpacked_sk->owf_input, SK_INPUT(sk), sizeof(unpacked_sk->owf_input));
  memcpy(unpacked_sk->owf_key, SK_KEY(sk), sizeof(unpacked_sk->owf_key));

  vhdsa_@PARAM_L@_owf(SK_KEY(sk), SK_INPUT(sk), unpacked_sk->owf_output);
  // declassify OWF output
  vhdsa_declassify(unpacked_sk->owf_output, sizeof(unpacked_sk->owf_output));

  const vhdsa_paramset_t* params = vhdsa_get_paramset(VHDSA_@PARAM@);
  aes_extend_witness(unpacked_sk->witness, unpacked_sk->owf_key, unpacked_sk->owf_input, params);

  return 0;
}

int VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_validate_keypair(const uint8_t* pk, const uint8_t* sk) {
  if (!sk || !pk) {
    return -1;
  }

  if ((ptr_get_bit(SK_KEY(sk), 0) & ptr_get_bit(SK_KEY(sk), 1)) != 0) {
    return 1;
  }

  uint8_t pk_check[@PK_SIZE@];
  vhdsa_@PARAM_L@_owf(SK_KEY(sk), SK_INPUT(sk), PK_OUTPUT(pk_check));
  memcpy(PK_INPUT(pk_check), SK_INPUT(sk), @OWF_INPUT_SIZE@);

  return vhdsa_timingsafe_bcmp(pk_check, pk, sizeof(pk_check)) == 0 ? 0 : 2;
}

int VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_sign_with_randomness(const uint8_t* sk, const uint8_t* message, size_t message_len, const uint8_t* rho, size_t rho_len, uint8_t* signature, size_t* signature_len) {
  if (!sk || !signature || !signature_len || *signature_len < VHDSA_@PARAM@_SIGNATURE_SIZE || (!rho && rho_len)) {
    return -1;
  }

  vhdsa_@PARAM_L@_unpacked_private_key_t unpacked_sk;
  int ret = vhdsa_@PARAM_L@_unpack_private_key(&unpacked_sk, sk);
  if (ret) {
    vhdsa_@PARAM_L@_clear_unpacked_private_key(&unpacked_sk);
    return ret;
  }

  ret = vhdsa_@PARAM_L@_unpacked_sign_with_randomness(&unpacked_sk, message, message_len, rho, rho_len, signature, signature_len);
  vhdsa_@PARAM_L@_clear_unpacked_private_key(&unpacked_sk);
  return ret;
}

int VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_sign(const uint8_t* sk, const uint8_t* message, size_t message_len, uint8_t* signature, size_t* signature_len, CRYPT_state* crypt_state) {
  if (!sk || !signature || !signature_len || *signature_len < VHDSA_@PARAM@_SIGNATURE_SIZE) {
    return -1;
  }

  uint8_t rho[VHDSA_@PARAM@_LAMBDA / 8];
  rand_bytes(rho, sizeof(rho));
  memcpy(crypt_state->rand, rho, sizeof(rho));

  return vhdsa_@PARAM_L@_sign_with_randomness(sk, message, message_len, rho, sizeof(rho), signature, signature_len);
}

int VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_unpacked_sign(const vhdsa_@PARAM_L@_unpacked_private_key_t* sk, const uint8_t* message, size_t message_len, uint8_t* signature, size_t* signature_len) {
  if (!sk || !signature || !signature_len || *signature_len < VHDSA_@PARAM@_SIGNATURE_SIZE) {
    return -1;
  }

  uint8_t rho[VHDSA_@PARAM@_LAMBDA / 8];
  rand_bytes(rho, sizeof(rho));

  return vhdsa_@PARAM_L@_unpacked_sign_with_randomness(sk, message, message_len, rho, sizeof(rho), signature, signature_len);
}

int VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_unpacked_sign_with_randomness(const vhdsa_@PARAM_L@_unpacked_private_key_t* sk, const uint8_t* message, size_t message_len, const uint8_t* rho, size_t rho_len, uint8_t* signature, size_t* signature_len) {
  if (!sk || !signature || !signature_len || *signature_len < VHDSA_@PARAM@_SIGNATURE_SIZE) {
    return -1;
  }

  const vhdsa_paramset_t* params = vhdsa_get_paramset(VHDSA_@PARAM@);
  vhdsa_sign(signature, message, message_len, sk->owf_key, sk->owf_input, sk->owf_output, sk->witness, rho, rho_len, params);
  *signature_len = VHDSA_@PARAM@_SIGNATURE_SIZE;

  return 0;
}

int VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_verify(const uint8_t* pk, const uint8_t* message, size_t message_len, const uint8_t* signature, size_t signature_len) {
  if (!pk || !signature || signature_len != VHDSA_@PARAM@_SIGNATURE_SIZE) {
    return -1;
  }

  const vhdsa_paramset_t* params = vhdsa_get_paramset(VHDSA_@PARAM@);
  return vhdsa_verify(message, message_len, signature, PK_INPUT(pk), PK_OUTPUT(pk), params);
}

void VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_clear_private_key(uint8_t* key) {
  vhdsa_explicit_bzero(key, VHDSA_@PARAM@_PRIVATE_KEY_SIZE);
}

void VHDSA_CALLING_CONVENTION vhdsa_@PARAM_L@_clear_unpacked_private_key(vhdsa_@PARAM_L@_unpacked_private_key_t* key) {
  vhdsa_explicit_bzero(key, sizeof(*key));
}

// vim: ft=c
